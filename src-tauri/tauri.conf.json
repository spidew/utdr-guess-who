{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "utdr-guess-who",
  "version": "1.1.0",
  "identifier": "com.wearsnomask.utdr-guess-who",
  "build": {
    "frontendDist": "../build/public"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "utdr-guess-who",
        "width": 1600,
        "height": 1000
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}